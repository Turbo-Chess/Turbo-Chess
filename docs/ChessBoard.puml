@startuml
skinparam classAttributeIconSize 0
hide empty fields
hide empty methods

class DefinitionCacheEntry <<DTO>> {
    + getPackId() : String
    + getPieceId() : String
    + getDefinition() : AbstractEntityDefinition
}

interface DefinitionRegistry <<Registry>> {
    + getDefinition(packId: String, pieceId: String) : DefinitionCacheEntry
    + registerDefinition(...) : void
}

interface BoardFactory <<Factory>> {
    + populateChessboard(whiteLoadout: Loadout, blackLoadout: Loadout, board: ChessBoard) : void
    + createNewPiece(pos: Point2D, board: ChessBoard, pieceDef: PieceDefinition, color: PlayerColor) : void
}

class BoardFactoryImpl {
    + populateChessboard(...) : void
    + createNewPiece(...) : void
}

BoardFactory <|.. BoardFactoryImpl

BoardFactoryImpl o--> "1" DefinitionRegistry : queries >
DefinitionRegistry ..> DefinitionCacheEntry : produces >
@enduml

LoaderController <|.. LoaderControllerImpl
BoardFactory <|.. BoardFactoryImpl

BoardFactoryImpl o--> "1" LoaderController : uses
@enduml