@startuml Loadout

skinparam classAttributeIconSize 0
hide empty fields
hide empty methods

class LoadoutEntry {
    - position : Point2D
    - packId : String
    - pieceId : String
}

class Loadout {
    - id : String
    - name : String
    - createdAt : long
    - updatedAt : long
    - entries : List<LoadoutEntry>

    +withName(newName : String) : Loadout
    +withEntries(newEntries : List<LoadoutEntry>) : Loadout
    +duplicate(newName : String) : Loadout
    +mirrored() : Loadout
    +getEntries() : List<LoadoutEntry>
    +isValid(definitions : Map<String, PieceDefinition>, standardLoadout : Loadout) : boolean
    +{static} create(name : String, entries : List<LoadoutEntry>) : Loadout

    -isValid(definitions : Map<String, PieceDefinition>, expectedWeight : int, standardLoadout : Loadout) : boolean
    -{static} calculateWeight(entries : List<LoadoutEntry>, definitions : Map<String, PieceDefinition>) : int
    -{static} validateWeight(ctx : ValidationContext) : boolean
    -{static} validateEntryCount(ctx : ValidationContext) : boolean
    -{static} validateKingCount(ctx : ValidationContext) : boolean
    -{static} validateDistinctPositions(ctx : ValidationContext) : boolean
    -{static} validateAllExist(ctx : ValidationContext) : boolean
    -{static} validatePositionsMatch(ctx : ValidationContext) : boolean
    -{static} validateWeightMatch(ctx : ValidationContext) : boolean
}

Loadout "1" *-- "*" LoadoutEntry : entries

class ValidationContext {
    - entries : List<LoadoutEntry>
    - definitions : Map<String, PieceDefinition>
    - expectedWeight : int
    - standardLoadout : Loadout
}

Loadout ..> ValidationContext
ValidationContext --> Loadout : standardLoadout
Loadout ..> ChessBoardImpl : uses CHESSBOARD_SIZE

@enduml
